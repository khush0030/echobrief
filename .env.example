# EchoBrief Environment Variables Template
# Copy this to .env.local and fill in your own values
# Never commit .env.local to Git!

# Frontend (Vite)
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
VITE_GOOGLE_OAUTH_CLIENT_ID=<your-google-client-id>
VITE_API_URL=http://localhost:5173

# Supabase Secrets (set in Supabase Dashboard → Project Settings → Secrets)
# These are for edge functions only - DO NOT include in frontend code
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
RECALL_API_KEY=<your-recall-api-key>
SARVAM_API_KEY=<your-sarvam-api-key>
OPENAI_API_KEY=<your-openai-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>
RESEND_API_KEY=<your-resend-api-key>
